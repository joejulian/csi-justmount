{
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
  ],
  labels: ["dependencies"],
  automergeType: "pr",
  platformAutomerge: true,
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  branchConcurrentLimit: 0,
  rebaseWhen: "behind-base-branch",
  packageRules: [
    {
      matchManagers: ["github-actions", "gomod", "dockerfile", "helm-values"],
      automerge: true,
      addLabels: ["automerge"],
    },
    {
      matchManagers: ["custom.regex"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      automerge: true,
      addLabels: ["automerge"],
    },
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^charts\\/justmount\\/values\\.ya?ml$/"],
      matchStrings: [
        "# renovate: image=(?<depName>[^\\s]+)\\n\\s*image:\\s*[\"']?(?<currentValue>[^\"'\\n]+)[\"']?",
      ],
      datasourceTemplate: "docker",
    },
  ],
}
